model Book {
  id            String   @id @default(uuid())
  title         String
  author        String   // assuming you already added @default("Unknown") or similar earlier
  description   String?
  genre         String?
  coverImage    String?
  publishedYear Int?
  pages         Int?
  rating        Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt   // ← Add @default(now()) here
}