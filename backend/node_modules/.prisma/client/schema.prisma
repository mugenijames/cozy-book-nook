datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Your models go here (keep or add your Book model)
model Book {
  id            String   @id @default(uuid())
  title         String
  author        String   @default("Unknown") // ← added default to avoid previous required-column error
  description   String?
  genre         String?
  coverImage    String?
  publishedYear Int?
  pages         Int?
  rating        Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
