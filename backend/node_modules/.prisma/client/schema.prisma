generator client {
  provider      = "prisma-client-js"
  // Added debian-openssl-3.0.x for Render compatibility
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Book {
  // Switched to String/UUID to match your controller logic
  id            String  @id @default(uuid())
  slug          String? @unique
  title         String
  author        String
  description   String?
  genre         String?
  coverImage    String?
  publishedYear Int?
  pages         Int?
  rating        Float   @default(0.0)
  priceCents    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([author])
  @@map("books")
}
